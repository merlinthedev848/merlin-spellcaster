/**
 * config.local.php.example
 *
 * Copy this file to config.local.php and fill in your credentials.
 * This file is NOT committed to git.
 *
 * On Enhance / cPanel hosting:
 *  - Create a MySQL database via your control panel
 *  - Create a database user and grant it ALL PRIVILEGES on the database
 *  - Fill in the credentials below
 */

$db_host = 'localhost';          // Usually 'localhost' on shared hosting
$db_name = 'username_dbname';   // e.g. 'johndoe_spellcaster' on cPanel
$db_user = 'username_dbuser';   // Database username
$db_pass = 'your-strong-password-here';
$db_port = 3306;                 // Default MySQL port
