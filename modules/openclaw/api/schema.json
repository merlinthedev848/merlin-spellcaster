{
  "openapi": "3.0.0",
  "info": {
    "title": "Merlin Spellcaster - OpenClaw Agent API",
    "description": "API allowing OpenClaw AI Agents to manage email lists and draft campaigns.",
    "version": "1.0.0"
  },
  "servers": [
    {
      "url": "http://localhost/modules/openclaw/api/gateway.php",
      "description": "Dynamic gateway (OpenClaw will automatically use the host URL)"
    }
  ],
  "components": {
    "securitySchemes": {
      "BearerAuth": {
        "type": "http",
        "scheme": "bearer"
      }
    }
  },
  "security": [
    {
      "BearerAuth": []
    }
  ],
  "paths": {
    "?action=stats": {
      "get": {
        "summary": "Get Dashboard Statistics",
        "operationId": "getDashboardStats",
        "responses": {
          "200": {
            "description": "Current platform stats including total subscribers and average open rates."
          }
        }
      }
    },
    "?action=draft_campaign": {
      "post": {
        "summary": "Draft a New Campaign",
        "operationId": "draftCampaign",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "subject": { "type": "string" },
                  "body_html": { "type": "string", "description": "HTML content of the email" }
                }
              }
            }
          }
        },
        "responses": {
          "200": { "description": "Campaign drafted successfully." }
        }
      }
    }
  }
}
