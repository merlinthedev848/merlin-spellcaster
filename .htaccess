Options -Indexes
DirectoryIndex index.php

<IfModule mod_rewrite.c>
    RewriteEngine On

    # Block direct access to sensitive directories/files
    RewriteRule ^config\.php$         - [F,L]
    RewriteRule ^config\.local\.php$  - [F,L]
    RewriteRule ^autoload\.php$       - [F,L]
    RewriteRule ^composer\.json$      - [F,L]
    RewriteRule ^core/                - [F,L]
    RewriteRule ^includes/            - [F,L]
    RewriteRule ^cron/(send|automation)\.php$ - [L]
    RewriteRule ^cron/                - [F,L]

    # Allow uploads directory for media
    RewriteRule ^uploads/             - [L]

    # API routing — forward to api/index.php with path info
    RewriteCond %{REQUEST_URI} ^/api/
    RewriteCond %{REQUEST_FILENAME} !-f
    RewriteRule ^api/(.*)$ /api/index.php [QSA,L]
</IfModule>

# ─── Security Headers ─────────────────────────────────────────────────────────
<IfModule mod_headers.c>
    Header always set X-Frame-Options "SAMEORIGIN"
    Header always set X-Content-Type-Options "nosniff"
    Header always set Referrer-Policy "strict-origin-when-cross-origin"
    Header always set X-XSS-Protection "1; mode=block"
    Header always set Permissions-Policy "camera=(), microphone=(), geolocation=()"
</IfModule>

# ─── PHP 8.5 Settings ─────────────────────────────────────────────────────────
<IfModule mod_php.c>
    php_value upload_max_filesize 16M
    php_value post_max_size 16M
    php_value max_execution_time 300
    php_value memory_limit 256M
    php_value max_input_vars 3000
    php_value session.cookie_httponly 1
    php_value session.cookie_samesite "Lax"
    php_value session.use_strict_mode 1
</IfModule>

# ─── OPCache Configuration (PHP 8.5) ──────────────────────────────────────────
<IfModule mod_php.c>
    php_flag  opcache.enable 1
    php_value opcache.memory_consumption 128
    php_value opcache.interned_strings_buffer 16
    php_value opcache.max_accelerated_files 10000
    php_flag  opcache.validate_timestamps 1
    php_value opcache.revalidate_freq 60
    php_flag  opcache.save_comments 0
    php_flag  opcache.enable_file_override 1
    # JIT compilation (PHP 8.5)
    php_value opcache.jit_buffer_size 64M
    php_value opcache.jit tracing
</IfModule>

# ─── Gzip Compression ─────────────────────────────────────────────────────────
<IfModule mod_deflate.c>
    AddOutputFilterByType DEFLATE text/html text/plain text/css
    AddOutputFilterByType DEFLATE text/javascript application/javascript application/json
    AddOutputFilterByType DEFLATE text/xml application/xml application/xhtml+xml
    AddOutputFilterByType DEFLATE image/svg+xml
</IfModule>

# ─── Browser Caching for Static Assets ─────────────────────────────────────────
<IfModule mod_expires.c>
    ExpiresActive On
    ExpiresByType text/css "access plus 1 month"
    ExpiresByType text/javascript "access plus 1 month"
    ExpiresByType application/javascript "access plus 1 month"
    ExpiresByType image/png "access plus 1 year"
    ExpiresByType image/gif "access plus 1 year"
    ExpiresByType image/jpeg "access plus 1 year"
    ExpiresByType image/webp "access plus 1 year"
    ExpiresByType image/svg+xml "access plus 1 month"
    ExpiresByType font/woff2 "access plus 1 year"
    ExpiresByType application/font-woff2 "access plus 1 year"
</IfModule>

# ─── ETags ─────────────────────────────────────────────────────────────────────
<IfModule mod_headers.c>
    <FilesMatch "\.(css|js|png|jpg|jpeg|gif|webp|woff2|svg)$">
        Header set Cache-Control "public, max-age=2592000, immutable"
    </FilesMatch>
</IfModule>
